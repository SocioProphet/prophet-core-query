{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.org/prophet-core-query/wallguard-query-context.schema.json",
  "title": "WallGuard Query Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "query_id",
    "workroom_ref",
    "subject_ref",
    "active_wall_ref",
    "assembly_phase",
    "context_pack_refs",
    "catalog_visibility_refs",
    "retrieval_filter_refs",
    "memory_gate_refs",
    "wall_decision_refs",
    "assembly_decision",
    "reason_code",
    "assembled",
    "policy_refs",
    "receipt_refs",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "record_type": {"const": "WallGuardQueryContext"},
    "query_id": {"type": "string", "minLength": 1},
    "workroom_ref": {"type": "string", "minLength": 1},
    "subject_ref": {"type": "string", "minLength": 1},
    "active_wall_ref": {"type": "string", "minLength": 1},
    "assembly_phase": {"enum": ["pre_context_assembly", "post_filter_pre_model"]},
    "context_pack_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "catalog_visibility_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "retrieval_filter_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "memory_gate_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "wall_decision_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "assembly_decision": {"enum": ["assemble", "deny", "redact", "quarantine", "fail_closed"]},
    "reason_code": {"type": "string", "minLength": 1},
    "assembled": {"type": "boolean"},
    "policy_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "receipt_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
