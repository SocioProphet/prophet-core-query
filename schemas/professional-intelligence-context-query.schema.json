{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.io/schemas/query/professional-intelligence-context-query.schema.json",
  "title": "ProfessionalIntelligenceContextQuery",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "queryId",
    "workroomRef",
    "playbookId",
    "issuedBy",
    "issuedAt",
    "inputs",
    "queryPlan",
    "outputs"
  ],
  "properties": {
    "schemaVersion": { "const": "v0.1" },
    "queryId": { "type": "string", "minLength": 1 },
    "workroomRef": { "type": "string", "minLength": 1 },
    "playbookId": { "type": "string", "minLength": 1 },
    "issuedBy": { "type": "string", "minLength": 1 },
    "issuedAt": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entityRefs",
        "searchPacketRefs",
        "contextPackRefs",
        "policyDecisionRefs",
        "obligationRefs",
        "evidenceRefs"
      ],
      "properties": {
        "entityRefs": { "type": "array", "items": { "type": "string" } },
        "relationshipRefs": { "type": "array", "items": { "type": "string" } },
        "searchPacketRefs": { "type": "array", "items": { "type": "string" } },
        "contextPackRefs": { "type": "array", "items": { "type": "string" } },
        "policyDecisionRefs": { "type": "array", "items": { "type": "string" } },
        "obligationRefs": { "type": "array", "items": { "type": "string" } },
        "evidenceRefs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "queryPlan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stepId", "source", "operation", "inputRefs", "outputRef", "evidenceRequired"],
        "properties": {
          "stepId": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "enum": ["sherlock-search", "memory-mesh", "policy-fabric", "contractforge", "prophet-workspace", "agent-registry", "prophet-platform"] },
          "operation": { "type": "string", "minLength": 1 },
          "inputRefs": { "type": "array", "items": { "type": "string" } },
          "outputRef": { "type": "string", "minLength": 1 },
          "evidenceRequired": { "type": "boolean" }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contextPackRefs", "workroomRefs", "evidenceRefs"],
      "properties": {
        "contextPackRefs": { "type": "array", "items": { "type": "string" } },
        "workroomRefs": { "type": "array", "items": { "type": "string" } },
        "evidenceRefs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
